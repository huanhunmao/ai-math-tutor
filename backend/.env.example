OPENAI_API_KEY=your-api-key
OPENAI_BASE_URL=https://api.moonshot.cn/v1
OPENAI_MODEL=moonshot-v1-8k
DATABASE_URL=
# Example Render PostgreSQL URL:
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Comma-separated allowed frontend origins in production.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Optional regex for preview domains, e.g. https://.*\.vercel\.app
CORS_ORIGIN_REGEX=

# Disable RAG during early deployment unless you have set up external vector storage.
RAG_ENABLED=false
RAG_MODEL_NAME=BAAI/bge-small-zh-v1.5
